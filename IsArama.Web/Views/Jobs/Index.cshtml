@model IsArama.Web.Models.JobListViewModel
@{
    ViewData["Title"] = "İş İlanları";
    var totalPages = (int)Math.Ceiling((double)Model.Response.Total / Math.Max(Model.PageSize, 1));
}
<div class="row mb-3">
    <div class="col">
        <form method="get" asp-action="Index">
            <input type="hidden" name="cityId" value="@Model.CityId" />
            <input type="hidden" name="workModelId" value="@Model.WorkModelId" />
            <input type="hidden" name="workTypeId" value="@Model.WorkTypeId" />
            <input type="hidden" name="pageSize" value="@Model.PageSize" />
            <div class="input-group input-group-lg shadow-sm">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="keyword" class="form-control border-start-0"
                       placeholder="Pozisyon veya şirket ara..." value="@Model.Keyword" />
                <button class="btn btn-primary px-4" type="submit">Ara</button>
            </div>
        </form>
    </div>
</div>

<div class="d-md-none mb-2">
    <button class="btn btn-outline-secondary btn-sm w-100" type="button"
            onclick="document.getElementById('filter-col').classList.toggle('d-none')">
        <i class="bi bi-funnel me-1"></i> Filtreler
    </button>
</div>
<div class="row g-4">
    <div class="col-12 col-md-3 d-none d-md-block" id="filter-col">
        <div class="card border-0 shadow-sm" id="filter-card">
            <div class="card-header bg-white fw-bold border-bottom d-flex justify-content-between align-items-center">
                <span><i class="bi bi-funnel me-1"></i> Filtreler</span>
                @if (Model.CityId != null || Model.WorkModelId != null || Model.WorkTypeId != null || Model.SectorId != null)
                {
                    <a href="@Url.Action("Index", new { keyword = Model.Keyword, pageSize = Model.PageSize })"
                       class="btn btn-sm btn-outline-danger rounded-pill">Temizle</a>
                }
            </div>
            <div class="card-body p-3">
                @* Şehir *@
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase text-muted">Şehir</label>
                    <select id="citySelect" class="form-select form-select-sm"
                            onchange="applyFilter('cityId', this.value)">
                        <option value="">Tüm Şehirler</option>
                        @foreach (var city in Model.Lookup.Cities)
                        {
                            <option value="@city.Id" selected="@(Model.CityId == city.Id)">@city.Name</option>

                        }
                    </select>
                </div>

                @* Sektör *@
                @if (Model.Lookup.Sectors.Any())
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-uppercase text-muted">Sektör</label>
                        <select class="form-select form-select-sm"
                                onchange="applyFilter('sectorId', this.value)">
                            <option value="">Tüm Sektörler</option>
                            @foreach (var sector in Model.Lookup.Sectors)
                            {
                                <option value="@sector.Id" selected="@(Model.SectorId == sector.Id)">@sector.Name</option>

                            }
                        </select>
                    </div>
                }

                @* Çalışma Modeli *@
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase text-muted">Çalışma Modeli</label>
                    <div class="d-flex flex-column gap-1">
                        <a href="@Url.Action("Index", new { keyword = Model.Keyword, cityId = Model.CityId, workTypeId = Model.WorkTypeId, sectorId = Model.SectorId, pageSize = Model.PageSize })"
                           class="btn btn-sm @(Model.WorkModelId == null ? "btn-primary" : "btn-outline-secondary") text-start">Tümü</a>
                        @foreach (var wm in Model.Lookup.WorkModels)
                        {
                            <a href="@Url.Action("Index", new { keyword = Model.Keyword, cityId = Model.CityId, workModelId = wm.Id, workTypeId = Model.WorkTypeId, sectorId = Model.SectorId, pageSize = Model.PageSize })"
                               class="btn btn-sm @(Model.WorkModelId == wm.Id ? "btn-primary" : "btn-outline-secondary") text-start">@wm.Name</a>
                        }
                    </div>
                </div>

                @* Çalışma Tipi *@
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-uppercase text-muted">Çalışma Tipi</label>
                    <div class="d-flex flex-column gap-1">
                        <a href="@Url.Action("Index", new { keyword = Model.Keyword, cityId = Model.CityId, workModelId = Model.WorkModelId, sectorId = Model.SectorId, pageSize = Model.PageSize })"
                           class="btn btn-sm @(Model.WorkTypeId == null ? "btn-primary" : "btn-outline-secondary") text-start">Tümü</a>
                        @foreach (var wt in Model.Lookup.WorkTypes)
                        {
                            <a href="@Url.Action("Index", new { keyword = Model.Keyword, cityId = Model.CityId, workModelId = Model.WorkModelId, workTypeId = wt.Id, sectorId = Model.SectorId, pageSize = Model.PageSize })"
                               class="btn btn-sm @(Model.WorkTypeId == wt.Id ? "btn-primary" : "btn-outline-secondary") text-start">@wt.Name</a>
                        }
                    </div>
                </div>

                @* Kaynak *@
                @if (Model.Lookup.Sources.Count > 1)
                {
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-uppercase text-muted">Kaynak</label>
                        <div class="d-flex flex-column gap-1">
                            <a href="@Url.Action("Index", new { keyword = Model.Keyword, cityId = Model.CityId, workModelId = Model.WorkModelId, workTypeId = Model.WorkTypeId, sectorId = Model.SectorId, pageSize = Model.PageSize })"
                               class="btn btn-sm @(Model.SourceId == null ? "btn-primary" : "btn-outline-secondary") text-start">Tümü</a>
                            @foreach (var src in Model.Lookup.Sources)
                            {
                                <a href="@Url.Action("Index", new { keyword = Model.Keyword, cityId = Model.CityId, workModelId = Model.WorkModelId, workTypeId = Model.WorkTypeId, sectorId = Model.SectorId, sourceId = src.Id, pageSize = Model.PageSize })"
                                       class="btn btn-sm @(Model.SourceId == src.Id ? "btn-primary" : "btn-outline-secondary") text-start d-flex align-items-center gap-2">
                                    <img src="@src.FaviconUrl" width="14" height="14" alt="@src.Name" />
                                    @src.Name
                                </a>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12 col-md-9">
        <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
            <span class="text-muted"><strong>@Model.Response.Total</strong> ilan bulundu</span>
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small">Sayfa başına:</span>
                @foreach (var size in new[] { 10, 25, 50, 75, 100 })
                {
                    <a asp-action="Index"
                       asp-route-pageSize="@size"
                       asp-route-page="1"
                       asp-route-keyword="@Model.Keyword"
                       asp-route-cityId="@Model.CityId"
                       asp-route-workModelId="@Model.WorkModelId"
                       asp-route-workTypeId="@Model.WorkTypeId"
                       class="btn btn-sm @(Model.PageSize == size ? "btn-primary" : "btn-outline-secondary")">@size</a>
                }
            </div>
        </div>
       

        <div id="jobs-scroll-area">
            @if (totalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center flex-wrap gap-1">
                        <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                                   asp-route-page="@(Model.Page - 1)"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Math.Min(2, totalPages); i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }

                        @if (Model.Page > 4)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }

                        @for (int i = Math.Max(3, Model.Page - 1); i <= Math.Min(totalPages - 2, Model.Page + 1); i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }

                        @if (Model.Page < totalPages - 3)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }

                        @for (int i = Math.Max(totalPages - 1, 3); i <= totalPages; i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.Page == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                                   asp-route-page="@(Model.Page + 1)"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }
            @foreach (var job in Model.Response.Jobs)
            {
                <div class="card border-0 shadow-sm mb-3 job-card mx-3" data-slug="@job.Slug" style="cursor:pointer">
                    <div class="card-body py-3 px-4">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <div class="flex-shrink-0">
                                @if (!string.IsNullOrEmpty(job.LogoUrl))
                                {
                                    <img src="@job.LogoUrl" alt="@job.Company"
                                         class="rounded border bg-white p-1"
                                         width="64" height="64" style="object-fit:contain;" />
                                }
                                else
                                {
                                    <div class="rounded border bg-white d-flex align-items-center justify-content-center"
                                         style="width:64px;height:64px;">
                                        <i class="bi bi-building text-muted fs-4"></i>
                                    </div>

                                }
                            </div>
                            <div class="flex-grow-1 min-width-0">
                                <h6 class="mb-1 fw-bold">@job.Title</h6>
                                <div class="text-muted small">@job.Company</div>
                            </div>
                            <div class="text-end flex-shrink-0">
                                <small class="text-muted">@job.PublishedAt</small>
                            </div>
                        </div>
                        <div class="d-flex align-items-center justify-content-between gap-2">
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                                    <i class="bi bi-geo-alt me-1"></i>@job.City
                                </span>
                                <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                                    <i class="bi bi-laptop me-1"></i>@job.WorkModel
                                </span>
                                <span class="badge rounded-pill bg-light text-dark border px-3 py-2">
                                    <i class="bi bi-clock me-1"></i>@job.WorkType
                                </span>
                            </div>
                            <a href="@job.Url" target="_blank"
                                   class="badge rounded-pill bg-white text-muted border px-3 py-2 text-decoration-none d-flex align-items-center gap-1 flex-shrink-0"
                                   onclick="event.stopPropagation()">
                                <img src="@job.SourceLogoUrl"
                                     style="max-width:80px; height:15px; object-fit:contain;"
                                     alt="@job.SourceName" />
                                @if (job.SourceName != "isinolsun.com")
                                {
                                    @job.SourceName
                                }
                            </a>
                        </div>
                    </div>
                </div>
            }

            @if (totalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center flex-wrap gap-1">
                        <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                                   asp-route-page="@(Model.Page - 1)"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">
                                <i class="bi bi-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Math.Min(2, totalPages); i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }

                        @if (Model.Page > 4)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }

                        @for (int i = Math.Max(3, Model.Page - 1); i <= Math.Min(totalPages - 2, Model.Page + 1); i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }

                        @if (Model.Page < totalPages - 3)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }

                        @for (int i = Math.Max(totalPages - 1, 3); i <= totalPages; i++)
                        {
                            <li class="page-item @(i == Model.Page ? "active" : "")">
                                <a class="page-link" asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">@i</a>
                            </li>
                        }

                        <li class="page-item @(Model.Page == totalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index"
                                   asp-route-page="@(Model.Page + 1)"
                                   asp-route-keyword="@Model.Keyword"
                                   asp-route-cityId="@Model.CityId"
                                   asp-route-workModelId="@Model.WorkModelId"
                                   asp-route-workTypeId="@Model.WorkTypeId"
                                   asp-route-pageSize="@Model.PageSize">
                                <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            }

        </div>
    </div>
</div>
<div class="modal fade" id="jobModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable modal-dialog-centered">
        <div class="modal-content" id="jobModalContent">
            <div class="modal-header border-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function adjustJobsHeight() {
            const el = document.getElementById('jobs-scroll-area');
            if (!el) return;
            const top = el.getBoundingClientRect().top;
            const footerH = document.querySelector('footer')?.offsetHeight || 0;
            el.style.maxHeight = (window.innerHeight - top - footerH - 8) + 'px';
        }
        adjustJobsHeight();
        window.addEventListener('resize', adjustJobsHeight);

        function applyFilter(param, value) {
            const url = new URL(window.location.href);
            url.searchParams.set('page', '1');
            if (value) {
                url.searchParams.set(param, value);
            } else {
                url.searchParams.delete(param);
            }
            window.location.href = url.toString();
        }

        document.querySelectorAll('.job-card[data-slug]').forEach(card => {
            card.addEventListener('click', async function () {
                const slug = this.dataset.slug;
                const modalEl = document.getElementById('jobModal');
                const modalContent = document.getElementById('jobModalContent');

                modalContent.innerHTML = `
                    <div class="modal-header border-0">
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body text-center py-5">
                        <div class="spinner-border text-primary"></div>
                        <div class="mt-3 text-muted small">İlan detayı yükleniyor...</div>
                    </div>`;

                const modal = new bootstrap.Modal(modalEl);
                modal.show();

                const response = await fetch(`/Jobs/DetailModal?slug=${slug}`);
                modalContent.innerHTML = await response.text();

                // Popover'ları başlat
                modalContent.querySelectorAll('[data-bs-toggle="popover"]').forEach(el => new bootstrap.Popover(el));
            });
        });
    </script>
}
