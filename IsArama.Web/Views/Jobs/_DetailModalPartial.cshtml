@model IsArama.Web.Models.JobDetailViewModel
@functions {
    static string FormatTurkishDate(string? dateStr)
    {
        if (string.IsNullOrEmpty(dateStr)) return "";
        if (DateTime.TryParse(dateStr, out var dt))
            return dt.ToString("d MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"));
        return dateStr;
    }
}

<div class="modal-header border-bottom px-4 py-2 align-items-start">
   
    <div class="d-flex gap-2 flex-shrink-0 ms-auto">
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal"></button>
    </div>
</div>

<div class="modal-body p-3 bg-light">
    @* İlan Bilgileri Kartı *@
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body d-flex align-items-center">
            <!-- Sol taraf: Logo -->
            @{
                var company = Model.Company; var companyName = company?.Name ?? "";
            }
            <div class="me-3">
                @if (company != null && !string.IsNullOrEmpty(company.LogoUrl))
                {
                    <img src="@company.LogoUrl" alt="@companyName"
                         class="rounded border bg-white p-1 flex-shrink-0"
                         width="80" height="80" style="object-fit:contain;" />
                }
                else
                {
                    <div class="d-flex align-items-center justify-content-center
                        rounded border bg-white flex-shrink-0"
                         style="width:80px; height:80px; font-weight:bold; font-size:20px; color:#258cfb;">
                        @(companyName.Length > 0 ? companyName.Substring(0, 1) : "?")
                    </div>
                }
            </div>

            <!-- Sağ taraf: Başlık + içerik -->
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h5 class="fw-bold mb-1">@Model.Title</h5>
                        <div class="text-muted small">@Model.Company?.Name</div>
                    </div>
                    <div>
                        <a href="@Model.Url" target="_blank" class="btn btn-primary btn-sm px-3">
                            <i class="bi bi-box-arrow-up-right me-1"></i>İlana Git
                        </a>
                    </div>
                </div>

                <!-- Konum, tarih, son başvuru -->
                <div class="d-flex flex-wrap gap-3 text-muted small mb-3">
                    @if (Model.City != null)
                    {
                        <span><i class="bi bi-geo-alt-fill me-1 text-primary"></i>@Model.City.Name@(Model.District != null ? $" ({Model.District.Name})" : "")</span>
                    }
                    @if (Model.PublishedAt.ToString() != "Son gün")
                    {
                        @if (!string.IsNullOrEmpty(Model.PublishedAt))
                        {
                            <span class="ms-auto">
                                <i class="bi bi-clock me-1"></i>@Model.PublishedAt  önce yayınlandı
                            </span>
                            <span class="ms-1 bi bi-info-circle text-primary"
                                  data-bs-toggle="popover"
                                  data-bs-html="true"
                                  data-bs-trigger="hover focus"
                                  data-bs-content="<strong>Yayınlanma Tarihi</strong><br>@FormatTurkishDate(Model.Detail?.PublishDate)<br><hr><strong>Kapanış Tarihi</strong><br>@FormatTurkishDate(Model.Detail?.ClosingDate)"
                                  style="cursor:pointer">
                            </span>
                        }
                    }
                    else
                    {
                        @if (!string.IsNullOrEmpty(Model.PublishedAt))
                        {
                            <span class="ms-auto text-danger">
                                <i class="bi bi-clock me-1"></i>@Model.PublishedAt
                            </span>
                            <span class="ms-1 bi bi-info-circle text-primary"
                                  data-bs-toggle="popover"
                                  data-bs-html="true"
                                  data-bs-trigger="hover focus"
                                  data-bs-content="<strong>Yayınlanma Tarihi</strong><br>@FormatTurkishDate(Model.Detail?.PublishDate)<br><hr><strong>Kapanış Tarihi</strong><br>@FormatTurkishDate(Model.Detail?.ClosingDate)"
                                  style="cursor:pointer">
                            </span>
                        }
                    }

                </div>

                <!-- Etiketler -->
                <div class="d-flex flex-wrap gap-2">
                    @if (Model.WorkModel != null)
                    {
                        <span class="badge border rounded-pill text-dark bg-white px-3 py-2 fw-normal">@Model.WorkModel.Name</span>
                    }
                    @if (Model.WorkType != null)
                    {
                        <span class="badge border rounded-pill text-dark bg-white px-3 py-2 fw-normal">@Model.WorkType.Name</span>
                    }
                    @if (Model.Detail?.PositionLevel != null)
                    {
                        <span class="badge border rounded-pill text-dark bg-white px-3 py-2 fw-normal">@Model.Detail.PositionLevel.Name</span>
                    }
                    @if (Model.Detail?.Sector != null)
                    {
                        <span class="badge border rounded-pill text-dark bg-white px-3 py-2 fw-normal">@Model.Detail.Sector.Name</span>
                    }
                    @{
                        var srcName = Model.Source?.Name ?? "kariyer.net";
                        var srcLogo = Model.Source?.LogoUrl ?? "https://www.kariyer.net/favicon.ico";
                    }
                    <a href="@Model.Url" target="_blank"
                           class="badge border rounded-pill text-muted bg-white px-3 py-2 fw-normal text-decoration-none d-flex align-items-center gap-1 ms-auto">
                        <img src="@srcLogo"
                             style="max-width:80px; height:15px; object-fit:contain;"
                             alt="@srcName" />
                        @if (srcName != "isinolsun.com")
                        {
                            @srcName
                        }
                    </a>
                </div>
            </div>
        </div>
    </div>
    @if (Model.Detail != null)
    {
        @* Açıklama Kartı *@
        <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h6 class="fw-bold mb-3">İş İlanı Hakkında</h6>
                <hr />
                @if (!string.IsNullOrEmpty(Model.Detail.HeaderImage))
                {
                    <div class="mb-4">
                        <img src="@Model.Detail.HeaderImage" alt="" class="img-fluid rounded w-100" />
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Detail.DescriptionHtml))
                {
                    <div class="job-description">
                        @Html.Raw(Model.Detail.DescriptionHtml)
                    </div>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-hourglass-split fs-2 d-block mb-2"></i>
                        Detay henüz çekilemedi.
                    </div>
                }
            </div>
        </div>
    }

    @* Şirket Kartı *@
    @if (Model.Company != null)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Şirket Hakkında</h6>
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(Model.Company.LogoUrl))
                    {
                        <img src="@Model.Company.LogoUrl" alt="@Model.Company.Name"
                             class="rounded border bg-white p-1 flex-shrink-0"
                             width="52" height="52" style="object-fit:contain;" />
                    }
                    <div class="flex-grow-1">
                        <div class="fw-semibold">@Model.Company.Name</div>
                        @if (!string.IsNullOrEmpty(Model.Company.Followers))
                        {
                            <div class="text-muted small">@Model.Company.Followers</div>
                        }
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div>
                        @if (!string.IsNullOrEmpty(Model.Company.ProfileUrl))
                        {
                            <a href="@Model.Company.ProfileUrl" target="_blank"
                                   class="text-decoration-none text-primary small fw-semibold">
                                Şirketin Diğer İlanları <i class="bi bi-chevron-right"></i>
                            </a>
                        }
                    </div>
                    <a href="@Model.Url" target="_blank" class="btn btn-primary btn-sm px-3 ms-auto">
                        <i class="bi bi-box-arrow-up-right me-1"></i>İlana Git
                    </a>
                </div>
            </div>
        </div>
    }

</div>

